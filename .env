# ===========================================
# Vite (frontend) – only VITE_* are exposed to client
# ===========================================
# Full URL of the PDF upload API (used when submitting the form)
VITE_PDF_UPLOAD_URL=http://localhost:3001

# ===========================================
# PDF server (node server.js) – run with: npm run server
# ===========================================
# Port for the PDF upload server (use 3001 so it doesn’t conflict with Vite on 5173)
PDF_SERVER_PORT=3001
# Base URL returned in the PDF link (must match where the PDF server is reachable)
BASE_URL=http://localhost:3001
